# Copy to src/main/resources/application.properties or set env vars
spring.application.name=reserva-restaurantes

# Either set SPRING_DATASOURCE_URL or configure host/db/credentials below
spring.datasource.url=jdbc:postgresql://localhost:5432/reserva_restaurante
spring.datasource.username=postgres
spring.datasource.password=postgres

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
server.port=8080